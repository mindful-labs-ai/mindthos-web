# SUPABASE Configuration
VITE_WEBAPP_SUPABASE_URL=your-supabase-url
VITE_WEBAPP_SUPABASE_ANON_KEY=your-supabase-anon-key

# mindthos-server 게이트웨이 (REST /v1 API)
# 배포 환경에서는 이 절대 URL로 호출. 비우면 로컬 dev에선 vite proxy가 게이트웨이로 forward.
VITE_SERVER_API_URL=your-server-api-url

# TOSS Configuration
VITE_TOSS_PAYMENTS_CLIENT_KEY=your-toss-payments-client-key

# Mixpanel Configuration
VITE_MIXPANEL_TOKEN=your-mixpanel-token

VITE_SESSION_API_URL=cloud-api-url

# Gemini AI Configuration (Server-side only)
GEMINI_API_KEY=your-gemini-api-key